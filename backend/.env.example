# NeuroLearn Environment Variables

# Backend Server Port
PORT=4000

# PostgreSQL Database Connection String
DATABASE_URL=postgresql://neurolearn:neurolearn_password@localhost:5432/neurolearn_db?schema=public

# JWT Authentication Secret
JWT_SECRET=production_strong_secret_key_change_me

# Redis Configuration (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# AI Microservice URL
AI_SERVICE_URL=http://localhost:8000

# Error Tracking (Optional)
SENTRY_DSN=
